{
  "base_path": "/api",
  "endpoints": {
    "GET /api/health": {
      "description": "Cek apakah API dan model aktif."
    },
    "GET /api/metadata": {
      "description": "Mengambil metadata proyek."
    },
    "GET /api/metrics": {
      "description": "Mengambil metrik model."
    },
